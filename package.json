{
    "name": "widget-enablement-examples",
    "version": "1.0.0",
    "description": "Widget Example using Vue.js",
    "main": "index.html",
    "engines": {
        "node": ">=18.0.0"
    },
    "config": {
        "publicPath": null
    },
    "scripts": {
        "postinstall": "node webpack/postInstall.js",
        "test": "mocha test/e2e/bootstrap.js --recursive test --timeout 10000",
        "debugTest": "mocha --inspect-brk test/bootstrap.js --recursive test --timeout 10000",
        "build": "webpack --config ./webpack/webpack.config.prod.js",
        "buildS3": "webpack --config ./webpack/webpack.config.prod.s3.js",
        "start": "webpack-dev-server --config ./webpack/webpack.config.dev.js --open",
        "startS3": "webpack-dev-server --config ./webpack/webpack.config.dev.s3.js",
        "debugS3": "node --inspect node_modules/webpack-dev-server/bin/webpack-dev-server.js --config ./webpack/webpack.config.dev.s3.js",
        "lint": "eslint src/**/*.js",
        "lintFix": "eslint src/**/*.js --fix",
        "lintMark": "markdownlint --config .markdownlint.json --ignore ./node_modules/** ./**/*.md",
        "lintMarkFix": "markdownlint --fix --config .markdownlint.json --ignore ./node_modules/** ./**/*.md"
    },
    "repository": {
        "type": "git",
        "url": "git@domain.com:project/repo.git"
    },
    "proxy": "https://localhost:8884",
    "author": "widget-lab",
    "license": "MIT",
    "devDependencies": {
        "@auth0/s3": "1.0.0",
